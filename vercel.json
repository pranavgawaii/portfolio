{
    "outputDirectory": "frontend/build",
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "functions": {
        "api/**/*.js": {
            "runtime": "nodejs20.x"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}